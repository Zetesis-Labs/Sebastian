# LiveKit Cloud — Project Settings → Keys
LIVEKIT_URL=wss://<tu-proyecto>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Realtime model provider. Use "gemini" for lower-cost Gemini Live, or "openai"
# for OpenAI Realtime fallback (defaults to gpt-realtime-mini).
SEBASTIAN_MODEL_PROVIDER=gemini

# Gemini Live API
GOOGLE_API_KEY=
SEBASTIAN_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
SEBASTIAN_GEMINI_VOICE=Puck

# OpenAI Realtime fallback
OPENAI_API_KEY=
SEBASTIAN_OPENAI_REALTIME_MODEL=gpt-realtime-mini
SEBASTIAN_OPENAI_VOICE=alloy
