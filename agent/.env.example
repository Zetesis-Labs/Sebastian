# LiveKit Cloud — Project Settings → Keys
LIVEKIT_URL=wss://<tu-proyecto>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Realtime model provider. Use "gemini" for lower-cost Gemini Live, or "openai"
# for OpenAI Realtime fallback (defaults to gpt-realtime-mini).
SEBASTIAN_MODEL_PROVIDER=gemini

# Gemini Live API
GOOGLE_API_KEY=
SEBASTIAN_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
SEBASTIAN_GEMINI_VOICE=Puck

# OpenAI Realtime fallback
OPENAI_API_KEY=
SEBASTIAN_OPENAI_REALTIME_MODEL=gpt-realtime-mini
SEBASTIAN_OPENAI_VOICE=alloy

# Language for the realtime model. Empty = auto-detect (required by the Gemini
# native-audio models, which reject explicit BCP-47 codes like es-ES).
SEBASTIAN_GEMINI_LANGUAGE=

# Home Assistant control (optional). Both must be set or HA control stays off.
# URL = the HA "MCP Server" integration SSE endpoint; token = a Long-Lived Access
# Token (HA → profile → Long-Lived Access Tokens).
SEBASTIAN_HA_MCP_URL=
SEBASTIAN_HA_TOKEN=

# Telemetry (optional). OTLP/HTTP endpoint for the agent's traces/metrics/logs;
# unset = no export. The device telemetry goes through tools/telemetry/bridge.py.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Token server (agent/token_server.py). Loopback by default; set HOST=0.0.0.0 to
# serve the device over the LAN.
SEBASTIAN_TOKEN_HOST=127.0.0.1
SEBASTIAN_TOKEN_PORT=8787

# Debug / dev toggles (optional). RECORD=1 dumps session audio to disk.
SEBASTIAN_RECORD=
SEBASTIAN_DEBUG=
