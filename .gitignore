# --- Secrets / local config (NUNCA commitear) ---
# sdkconfig contiene credenciales WiFi y de LiveKit en claro.
firmware/sdkconfig
firmware/sdkconfig.old
firmware/sdkconfig.local
**/.env

# --- ESP-IDF build artifacts ---
firmware/build/
firmware/managed_components/
firmware/include/bindings.h

# --- Web installer generated artifacts ---
# The whole published site is built in CI (pages.yml: pnpm build → docs/installer,
# then the factory firmware is merged in). Nothing here is hand-maintained, so the
# build is never committed — the source of truth is web-installer/.
docs/installer/
# (Binaries under docs/installer/firmware/ can embed local WiFi/token config;
# only the CI-built factory image, which carries no credentials, is published.)

# --- Zig ---
firmware/.zig-cache/
firmware/zig-out/
firmware/zig-relsafe-*/

# --- Python ---
agent/.venv/
__pycache__/
*.pyc

# --- macOS ---
.DS_Store

# Conexión LiveKit del dispositivo (token)
firmware/main/secrets.zig

# ESPHome secrets (WiFi)
homeassistant/secrets.yaml
homeassistant/.esphome/

# --- Wake word: datasets y toolchain de entrenamiento (~40GB) ---
# Los scripts, el modelo final y su metadata SÍ se versionan
# (wakeword/*.py, wakeword/*.md, wakeword/*.json, wakeword/*.tflite).
wakeword/trainer/

# Web installer firmware (generated, gitignored like docs/installer)
web-installer/public/firmware/*.bin
web-installer/public/*.local.json
web-installer/node_modules/
web-installer/dist/
dashboard/node_modules/
dashboard/.output/
.devcontainer/.env
agent/recordings/
agent/phantoms/
